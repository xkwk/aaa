# Snowflake browser SSO is the default.
ACT_SNOWFLAKE_AUTHENTICATOR=externalbrowser
ACT_SNOWFLAKE_ACCOUNT=
ACT_SNOWFLAKE_USER=
ACT_SNOWFLAKE_ROLE=
ACT_SNOWFLAKE_WAREHOUSE=
ACT_SNOWFLAKE_DATABASE=

# Only for authenticator=snowflake.
ACT_SNOWFLAKE_PASSWORD=

# Only for authenticator=oauth.
ACT_SNOWFLAKE_TOKEN=

