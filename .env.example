# Snowflake target
ACT_SNOWFLAKE_ACCOUNT=
ACT_SNOWFLAKE_USER=
ACT_SNOWFLAKE_AUTHENTICATOR=externalbrowser
# Only set for authenticator=snowflake.
ACT_SNOWFLAKE_PASSWORD=
# Only set for authenticator=oauth.
ACT_SNOWFLAKE_TOKEN=
ACT_SNOWFLAKE_ROLE=
ACT_SNOWFLAKE_WAREHOUSE=
ACT_SNOWFLAKE_DATABASE=ACTUARIAL_AI_DEV
ACT_SNOWFLAKE_SCHEMA_RAW=RAW
ACT_SNOWFLAKE_SCHEMA_CURATED=CURATED
ACT_SNOWFLAKE_SCHEMA_RUNS=RUNS
ACT_SNOWFLAKE_SCHEMA_APP=APP

# Optional: set to 1 for local demo/test runs without Snowflake.
ACT_OFFLINE=0
